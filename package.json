{
  "name": "ECommerseApp",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "web": "npm run web:build && npm run web:serve",
    "web:build": "webpack --config webpack.config.js",
    "web:serve": "kill-port 3000 && serve -s dist-web -l 3000",
    "web:dev": "kill-port 3000 && NODE_OPTIONS=--max-old-space-size=4096 webpack serve --config webpack.config.js --no-hot --no-open"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.1.1",
    "@react-native-vector-icons/ionicons": "^13.1.2",
    "@react-native/new-app-screen": "0.86.0",
    "@react-navigation/bottom-tabs": "^7.18.2",
    "@react-navigation/native": "^7.3.3",
    "@react-navigation/native-stack": "^7.17.5",
    "react": "19.2.3",
    "react-dom": "^19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "^3.0.1",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.25.2",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/eslint-config": "0.86.0",
    "@react-native/jest-preset": "^0.86.0",
    "@react-native/metro-config": "0.86.0",
    "@react-native/typescript-config": "0.86.0",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "babel-loader": "^10.1.1",
    "eslint": "^8.19.0",
    "html-webpack-plugin": "^5.6.7",
    "jest": "^29.6.3",
    "kill-port": "^2.0.1",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "serve": "^14.2.6",
    "typescript": "^5.8.3",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "webpack-dev-server": "^5.2.5"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
